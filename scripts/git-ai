#!/bin/bash
# git-ai — AI-powered commit message generator using Groq API
#
# Usage: git-ai [OPTIONS] [HINT]
#
# Options:
#   -A, --add            Run 'git add .' before committing
#   -D, --no-doc-check   Skip the documentation completeness check
#   -h, --help           Show this help message
#
# Arguments:
#   HINT                 Optional context hint to guide the commit message
#
# Examples:
#   git-ai                          Generate commit message with doc check
#   git-ai "refactoring auth flow"  Provide context hint for better message
#   git-ai -A                       Stage all changes first
#   git-ai -D                       Skip documentation check
#   git-ai -D "quick fix"           Skip doc check with context hint

# --- Help flag ---
for arg in "$@"; do
    if [ "$arg" = "-h" ] || [ "$arg" = "--help" ]; then
        sed -n '2,/^[^#]/{ /^#/s/^# \?//p }' "$0"
        exit 0
    fi
done

# 0. Check Dependencies
if ! command -v jq &>/dev/null; then
    echo "❌ Error: 'jq' is not installed."
    echo "Install it with: sudo dnf install jq (or sudo apt install jq)"
    exit 1
fi
if [ -z "$GROQ_API_KEY" ]; then
    echo "❌ Error: GROQ_API_KEY is missing."
    exit 1
fi

# --- Parse flags and arguments ---
SKIP_DOC_CHECK=false
ADD_ALL=false
USER_HINT=""
for arg in "$@"; do
    case "$arg" in
        --no-doc-check|-D) SKIP_DOC_CHECK=true ;;
        --add|-A) ADD_ALL=true ;;
        *) USER_HINT="$arg" ;;
    esac
done

# Stage all changes if requested
if [ "$ADD_ALL" = true ]; then
    git add .
fi

# 1. Check for Staged Changes
if git diff --cached --quiet; then
    echo "Error: No staged changes to commit."
    exit 1
fi

HINT_SECTION=""
if [ -n "$USER_HINT" ]; then
    HINT_SECTION="USER INTENT/CONTEXT: $USER_HINT"
fi
# ---------------------------------

# 2. Gather Context
DIFF_STAT=$(git diff --cached --stat)
FILE_STATUS=$(git diff --cached --name-status)

EXCLUDE_PATTERNS=(
    ':(exclude)package-lock.json'
    ':(exclude)yarn.lock'
    ':(exclude)*.lock'
    ':(exclude)*.svg'
    ':(exclude)*.out'
    ':(exclude)*.log'
    ':(exclude)*.png'
    ':(exclude)*.jpg'
    ':(exclude)*.gif'
    ':(exclude)*.pdf'
    ':(exclude)dist/*'
    ':(exclude)build/*'
    ':(exclude).next/*'
)

# Smart diff gathering: reduce context lines based on number of changed files
CHANGED_FILES=$(git diff --cached --name-only | wc -l)

if [ "$CHANGED_FILES" -gt 20 ]; then
    CONTEXT_LINES="-U0"
    MAX_CHARS=4000
elif [ "$CHANGED_FILES" -gt 10 ]; then
    CONTEXT_LINES="-U0"
    MAX_CHARS=8000
else
    CONTEXT_LINES="-U1"
    MAX_CHARS=12000
fi

DIFF_DETAILED=$(git diff --cached "$CONTEXT_LINES" -- . "${EXCLUDE_PATTERNS[@]}" | head -c "$MAX_CHARS")

PROJECT_STRUCTURE=$(tree -L 2 --gitignore -I '.git|node_modules|dist|build|coverage' --noreport 2>/dev/null || echo "Structure not available")

# 3. Build prompt messages (system + user)
SYSTEM_PROMPT="You write Conventional Commit messages. Output ONLY the commit message, nothing else.

FORMAT:
- Single logical change: <type>: <subject>
- Multiple independent changes:
  <type>: <short overall summary>

  - <type>: <change 1>
  - <type>: <change 2>

RULES:
- Group by intent, not by file. Deleting a feature's script + removing its config + removing its docs = one removal, not three.
- Only use multi-line when there are truly independent purposes.
- Imperative mood. No markdown. No explanations."

build_user_prompt() {
    local diff_content="$1"
    echo "${HINT_SECTION:+$HINT_SECTION
}
FILE STATUS (A=added, M=modified, D=deleted, R=renamed):
$FILE_STATUS

STAT:
$DIFF_STAT

PROJECT STRUCTURE:
$PROJECT_STRUCTURE

DIFF:
$diff_content"
}

# Rough token estimator (conservative: 1 token ≈ 3 chars)
estimate_tokens() {
    local text="$1"
    local char_count=${#text}
    echo $((char_count / 3))
}

# Build prompt
USER_PROMPT=$(build_user_prompt "$DIFF_DETAILED")
FULL_PROMPT="$SYSTEM_PROMPT$USER_PROMPT"
TOKEN_COUNT=$(estimate_tokens "$FULL_PROMPT")

# Log token count
if [ "$TOKEN_COUNT" -gt 10000 ]; then
    echo "⚠️  Prompt large ($TOKEN_COUNT tokens), using reduced diff" >&2
else
    echo "📊 Prompt size: ~$TOKEN_COUNT tokens" >&2
fi

# 4. Run Groq API with a spinner
echo -n "Thinking (Cloud)..."
(while :; do for c in / - \\ \|; do
    echo -ne "\b$c"
    sleep 0.1
done; done) &
SPINNER_PID=$!

JSON_SYSTEM=$(echo "$SYSTEM_PROMPT" | jq -R -s '.')
JSON_USER=$(echo "$USER_PROMPT" | jq -R -s '.')
RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
    -H "Authorization: Bearer $GROQ_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"llama-3.3-70b-versatile\",
        \"messages\": [
            {\"role\": \"system\", \"content\": $JSON_SYSTEM},
            {\"role\": \"user\", \"content\": $JSON_USER}
        ],
        \"temperature\": 0.1,
        \"max_tokens\": 300
     }")

kill $SPINNER_PID 2>/dev/null
echo -ne "\b \n"

# 5. Extract and Clean
MSG=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty')
MSG=$(echo "$MSG" | sed -e '/^```/d' -e 's/^[[:space:]]*$//' | sed -e '1s/^[[:space:]]*//' -e '${s/[[:space:]]*$//}')

if [ -z "$MSG" ] || [ "$MSG" == "null" ]; then
    echo "❌ Error: Model returned an empty string."
    echo "📋 API Response:"
    echo "$RESPONSE" | jq '.'
    exit 1
fi

# 6. Documentation Check
if [ "$SKIP_DOC_CHECK" = true ]; then
    echo "⏭️  Documentation check skipped (--no-doc-check)"
else
DOC_CHECK_PROMPT="Role: Senior Developer reviewing a commit for documentation completeness.

COMMIT MESSAGE:
$MSG

FILE STATUS:
$FILE_STATUS

FILES CHANGED:
$DIFF_STAT

FULL DIFF:
$DIFF_DETAILED

Task: Analyze the actual code changes and determine if documentation updates are needed and, if present, whether they are accurate and sufficient.

Consider these as documentation: README files, docs/ directories, man pages, inline help text, CHANGELOG, API docs, comments explaining public interfaces, docstrings, and config examples.

Rules:
- If the changes are ONLY documentation, config, tests, refactoring, internal logic, or trivial fixes: respond with exactly \"PASS\"
- If the changes add/remove/change user-facing behavior, CLI flags, APIs, or important workflows:
  - If no documentation is included and it would clearly benefit users: respond with \"FAIL: <what's missing>\"
  - If documentation IS included, verify it matches the actual code changes. If it's inaccurate or incomplete: respond with \"FAIL: <what's wrong>\"
  - If documentation IS included and accurately reflects the changes: respond with \"PASS\"
- Do NOT demand docs for minor internal changes, variable renames, dependency bumps, or changes that are self-explanatory from the commit message
- Output ONLY \"PASS\" or \"FAIL: <reason>\". No other text."

JSON_DOC_PROMPT=$(echo "$DOC_CHECK_PROMPT" | jq -R -s '.')

echo -n "Checking documentation..."
(while :; do for c in / - \\ \|; do
    echo -ne "\b$c"
    sleep 0.1
done; done) &
DOC_SPINNER_PID=$!

DOC_RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
    -H "Authorization: Bearer $GROQ_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"llama-3.3-70b-versatile\",
        \"messages\": [{\"role\": \"user\", \"content\": $JSON_DOC_PROMPT}],
        \"temperature\": 0.0,
        \"max_tokens\": 150
     }")

kill $DOC_SPINNER_PID 2>/dev/null
echo -ne "\b \n"

DOC_RESULT=$(echo "$DOC_RESPONSE" | jq -r '.choices[0].message.content // empty' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

if echo "$DOC_RESULT" | grep -qi "^FAIL"; then
    echo "❌ Documentation missing — commit blocked."
    echo "📝 $DOC_RESULT"
    echo ""
    echo "Commit message would have been:"
    echo "  $MSG"
    echo ""
    echo "Stage documentation updates and try again, or use --no-doc-check to skip."
    exit 1
fi
fi # end SKIP_DOC_CHECK

# 7. Commit
git commit -e -m "$MSG"
